{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist/native",
    "declaration": false,
    "declarationMap": false,
    "declarationDir": null
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}

