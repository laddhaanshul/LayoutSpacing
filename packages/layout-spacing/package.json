{
  "name": "@laddhaanshul/layout-spacing",
  "version": "1.0.1",
  "description": "A unified layout, spacing, responsive, and aspect-ratio system for React & React Native. Token-based 8pt grid spacing engine with Box, Flex, Stack primitives, responsive hooks, and AspectRatio component.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "react-native": "./dist/native/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts",
      "react-native": "./dist/native/index.js"
    },
    "./spacing-system": {
      "import": "./dist/esm/spacing-system/index.js",
      "require": "./dist/cjs/spacing-system/index.js",
      "types": "./dist/types/spacing-system/index.d.ts",
      "react-native": "./dist/native/spacing-system/index.js"
    },
    "./layout-primitives": {
      "import": "./dist/esm/layout-primitives/index.js",
      "require": "./dist/cjs/layout-primitives/index.js",
      "types": "./dist/types/layout-primitives/index.d.ts",
      "react-native": "./dist/native/layout-primitives/index.js"
    },
    "./responsive-hooks": {
      "import": "./dist/esm/responsive-hooks/index.js",
      "require": "./dist/cjs/responsive-hooks/index.js",
      "types": "./dist/types/responsive-hooks/index.d.ts",
      "react-native": "./dist/native/responsive-hooks/index.js"
    },
    "./aspect-ratio": {
      "import": "./dist/esm/aspect-ratio/index.js",
      "require": "./dist/cjs/aspect-ratio/index.js",
      "types": "./dist/types/aspect-ratio/index.d.ts",
      "react-native": "./dist/native/aspect-ratio/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:native",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:native": "tsc -p tsconfig.native.json",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.68.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-native": "^0.72.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.72.8",
    "react-test-renderer": "^18.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "react",
    "react-native",
    "layout",
    "spacing",
    "8pt-grid",
    "design-tokens",
    "responsive",
    "aspect-ratio",
    "box",
    "flex",
    "stack",
    "components",
    "ui",
    "cross-platform"
  ],
  "author": "Anshul Laddha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laddhaanshul/LayoutSpacing.git"
  },
  "bugs": {
    "url": "https://github.com/laddhaanshul/LayoutSpacing/issues"
  },
  "homepage": "https://layoutspacing.anshulladdha.in"
}