{
  "name": "layout-spacing-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for @laddhaanshul/layout-spacing - A unified layout, spacing, responsive, and aspect-ratio system for React & React Native",
  "scripts": {
    "build": "pnpm --filter @laddhaanshul/layout-spacing build",
    "test": "pnpm --filter @laddhaanshul/layout-spacing test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "example:web": "pnpm --filter layout-spacing-web-example dev",
    "example:native": "pnpm --filter layout-spacing-native-example start"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-native": "^0.72.8",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/laddhaanshul/LayoutSpacing.git"
  }
}
